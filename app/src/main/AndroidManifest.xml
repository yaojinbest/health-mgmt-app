<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".HealthApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.HealthMgmt"
        tools:targetApi="31">

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.HealthMgmt.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.login.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.login.ServerConfigActivity"
            android:exported="false"
            android:label="服务器地址设置"
            android:theme="@style/Theme.HealthMgmt.NoActionBar"
            android:parentActivityName=".ui.login.LoginActivity" />

        <!-- D4: 用药管理 + 健康档案 -->
        <activity
            android:name=".ui.medicine.MedicineActivity"
            android:exported="false"
            android:label="用药管理"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.archive.ArchiveActivity"
            android:exported="false"
            android:label="健康档案"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <!-- D5: SOS + 联系人 + 文章 -->
        <activity
            android:name=".ui.emergency.SosActivity"
            android:exported="false"
            android:label="紧急求救"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.emergency.ContactsActivity"
            android:exported="false"
            android:label="紧急联系人"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.article.ArticlesActivity"
            android:exported="false"
            android:label="健康文章"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.article.ArticleDetailActivity"
            android:exported="false"
            android:label="文章详情"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <!-- D6: 在线咨询 -->
        <activity
            android:name=".ui.consultation.ConsultationsActivity"
            android:exported="false"
            android:label="在线咨询"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.consultation.ChatActivity"
            android:exported="false"
            android:label="咨询聊天"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false"
            android:label="数据统计"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.medical.MedicalActivity"
            android:exported="false"
            android:label="预约就诊"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.medical.MyAppointmentsActivity"
            android:exported="false"
            android:label="我的预约"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

        <activity
            android:name=".ui.health.HealthDataChartActivity"
            android:exported="false"
            android:label="健康数据图表"
            android:theme="@style/Theme.HealthMgmt.NoActionBar" />

    </application>

</manifest>

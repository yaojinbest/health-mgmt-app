<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.HealthMgmt" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/info</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor" tools:targetApi="lollipop">@color/primary</item>
    </style>

    <style name="Theme.HealthMgmt.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- 卡片标题 -->
    <style name="CardTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 表单 -->
    <style name="FormLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_regular</item>
    </style>

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DangerButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="GhostButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:minHeight">44dp</item>
    </style>

    <!-- 首页快捷入口 -->
    <style name="QuickEntry">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">?selectableItemBackground</item>
    </style>

    <style name="QuickEntryIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="QuickEntryText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>

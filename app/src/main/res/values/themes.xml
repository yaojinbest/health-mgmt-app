<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.HealthMgmt" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/info</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor" tools:targetApi="lollipop">@color/primary</item>
    </style>

    <style name="Theme.HealthMgmt.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- 卡片标题 -->
    <style name="CardTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 表单 -->
    <style name="FormLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_regular</item>
    </style>

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DangerButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="GhostButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:minHeight">44dp</item>
    </style>
</resources>
